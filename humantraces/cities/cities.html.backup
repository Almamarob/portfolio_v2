        <script src="map.js"></script>
        <script>
            function navigateToCity(url) {
                if (url) {
                    window.location.href = url;
                }
            }

            function showCityDropdown() {
                document.getElementById("city-dropdown").style.display =
                    "block";
            }

            function hideCityDropdown() {
                document.getElementById("city-dropdown").style.display = "none";
            }

            function filterCities(searchTerm) {
                const dropdown = document.getElementById("city-dropdown");
                const groups = dropdown.querySelectorAll(".city-group");
                const term = searchTerm.toLowerCase();

                if (term === "") {
                    groups.forEach((group) => (group.style.display = "block"));
                    dropdown.style.display = "block";
                    return;
                }

                let hasResults = false;
                groups.forEach((group) => {
                    const searchData = group.getAttribute("data-search");
                    if (searchData && searchData.includes(term)) {
                        group.style.display = "block";
                        hasResults = true;
                    } else {
                        group.style.display = "none";
                    }
                });

                dropdown.style.display = hasResults ? "block" : "none";
            }

            // Close dropdown when clicking outside
            document.addEventListener("click", function (event) {
                const selector = document.querySelector(".city-selector");
                if (selector && !selector.contains(event.target)) {
                    hideCityDropdown();
                }
            });
        </script>
    </body>
